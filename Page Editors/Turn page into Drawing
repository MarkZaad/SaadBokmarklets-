javascript:(function(){var box=document.createElement('div');box.id='paint-toolbox';box.style='position:fixed;top:50px;left:20px;width:120px;background:#222;color:white;padding:10px;border-radius:8px;z-index:2147483647;font-family:sans-serif;box-shadow:0 4px 15px rgba(0,0,0,0.5);text-align:center;user-select:none;';box.innerHTML='<b style="font-size:12px;display:block;margin-bottom:8px;color:#aaa;cursor:move;">🎨 PAINT BOX</b>';var currentTool='none',isDrawing=false,startX,startY,activeElement;function createToolButton(id,label,color){var btn=document.createElement('button');btn.innerText=label;btn.style=`width:100%;margin:4px 0;padding:6px;background:${color};color:white;border:none;border-radius:4px;cursor:pointer;font-weight:bold;font-size:11px;transition:0.2s;`;btn.onclick=function(){box.querySelectorAll('button').forEach(b=>b.style.outline='none');if(currentTool===id){currentTool='none';}else{currentTool=id;btn.style.outline='2px solid #00ffff';}};box.appendChild(btn);}createToolButton('rect','🟥 Square','#ff4444');createToolButton('circle','⭕ Circle','#44aaff');createToolButton('text','✍️ Text Box','#44ffaa');var closeBtn=document.createElement('button');closeBtn.innerText='❌ Close';closeBtn.style='width:100%;margin-top:8px;padding:4px;background:#555;color:white;border:none;border-radius:4px;cursor:pointer;font-size:10px;';closeBtn.onclick=function(){box.remove();document.removeEventListener('mousedown',startPaint);document.removeEventListener('mousemove',paintMove);document.removeEventListener('mouseup',endPaint);};box.appendChild(closeBtn);document.body.appendChild(box);var isDraggingBox=false,boxOffsetX=0,boxOffsetY=0;box.firstChild.onmousedown=function(e){isDraggingBox=true;boxOffsetX=e.clientX-box.offsetLeft;boxOffsetY=e.clientY-box.offsetTop;};function startPaint(e){if(box.contains(e.target)||currentTool==='none'||isDraggingBox)return;isDrawing=true;startX=e.clientX+window.scrollX;startY=e.clientY+window.scrollY;if(currentTool==='rect'){activeElement=document.createElement('div');activeElement.style.border='3px solid #ff4444';activeElement.style.backgroundColor='rgba(255, 68, 68, 0.2)';}else if(currentTool==='circle'){activeElement=document.createElement('div');activeElement.style.border='3px solid #44aaff';activeElement.style.backgroundColor='rgba(68, 170, 255, 0.2)';activeElement.style.borderRadius='50%';}else if(currentTool==='text'){activeElement=document.createElement('textarea');activeElement.placeholder='Type here...';activeElement.style.border='2px dashed #44ffaa';activeElement.style.backgroundColor='rgba(255,255,255,0.9)';activeElement.style.color='black';activeElement.style.fontFamily='sans-serif';activeElement.style.padding='5px';activeElement.style.resize='none';}activeElement.style.position='absolute';activeElement.style.left=startX+'px';activeElement.style.top=startY+'px';activeElement.style.zIndex='2147483646';document.body.appendChild(activeElement);}function paintMove(e){if(isDraggingBox){box.style.left=(e.clientX-boxOffsetX)+'px';box.style.top=(e.clientY-boxOffsetY)+'px';return;}if(!isDrawing||!activeElement)return;var currentX=e.clientX+window.scrollX;var currentY=e.clientY+window.scrollY;var width=Math.abs(currentX-startX);var height=Math.abs(currentY-startY);activeElement.style.width=width+'px';activeElement.style.height=height+'px';activeElement.style.left=(currentX<startX?currentX:startX)+'px';activeElement.style.top=(currentY<startY?currentY:startY)+'px';}function endPaint(){isDrawing=false;isDraggingBox=false;if(activeElement&&(currentTool==='rect'||currentTool==='circle')){var shape=activeElement;shape.title='Double click to erase';shape.ondblclick=function(){shape.remove();};}activeElement=null;}document.addEventListener('mousedown',startPaint);document.addEventListener('mousemove',paintMove);document.addEventListener('mouseup',endPaint);})();
