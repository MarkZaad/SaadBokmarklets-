javascript:(function(){var elements=document.querySelectorAll('div,p,img,h1,h2,h3,span,button');elements.forEach(el=>{el.style.position='relative';el.draggable=true;el.ondragstart=e=>{e.dataTransfer.setData('text/plain',null);var opt={el:el,x:e.clientX-el.offsetLeft,y:e.clientY-el.offsetTop};window.activeDrag=opt;};});document.ondragover=e=>e.preventDefault();document.ondrop=e=>{e.preventDefault();if(window.activeDrag){var opt=window.activeDrag;opt.el.style.left=(e.clientX-opt.x)+'px';opt.el.style.top=(e.clientY-opt.y)+'px';}};alert('Drag mode on! Grab anything and move it.');})();
