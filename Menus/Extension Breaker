javascript:(function(){if(document.getElementById('gh-paint-canvas')){document.getElementById('gh-paint-wrapper').remove();document.getElementById('gh-paint-canvas').remove();document.getElementById('gh-paint-sig').remove();return;}const c=document.createElement('canvas');c.id='gh-paint-canvas';c.width=window.innerWidth;c.height=window.innerHeight;c.style='position:fixed;top:0;left:0;z-index:99998;pointer-events:auto;cursor:crosshair;';document.body.appendChild(c);const ctx=c.getContext('2d');let d=false,mode='brush';const w=document.createElement('div');w.id='gh-paint-wrapper';w.style='position:fixed;top:20px;left:20px;z-index:99999;background:rgba(30,30,30,0.85);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.1);padding:20px;border-radius:16px;box-shadow:0 20px 40px rgba(0,0,0,0.6);display:flex;flex-direction:column;gap:15px;color:white;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;width:180px;user-select:none;';w.innerHTML='<div style="font-weight:bold;font-size:14px;letter-spacing:1px;text-transform:uppercase;color:#aaa;border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:8px;display:flex;justify-content:between;align-items:center;"><span>Paint Studio</span><button id="gh-p-close" style="background:none;color:#ff5f56;border:none;cursor:pointer;font-weight:bold;font-size:16px;margin-left:auto;">✕</button></div><div style="display:flex;flex-direction:column;gap:10px;"><label style="font-size:12px;color:#aaa;display:flex;justify-content:space-between;">Color <input type="color" id="gh-p-color" value="#00ffcc" style="border:none;background:none;width:30px;height:20px;cursor:pointer;"></label><label style="font-size:12px;color:#aaa;display:flex;flex-direction:column;gap:5px;">Size <input type="range" id="gh-p-size" min="1" max="50" value="8" style="width:100%;cursor:pointer;accent-color:#00ffcc;"></label></div><div style="display:flex;flex-direction:column;gap:8px;margin-top:5px;"><button id="gh-p-brush" style="background:#00ffcc;color:#111;border:none;padding:8px;border-radius:8px;cursor:pointer;font-weight:bold;transition:0.2s;">🖌️ Brush</button><button id="gh-p-erase" style="background:rgba(255,255,255,0.1);color:white;border:none;padding:8px;border-radius:8px;cursor:pointer;font-weight:bold;transition:0.2s;">🧽 Eraser</button></div><div style="display:flex;gap:8px;margin-top:5px;border-top:1px solid rgba(255,255,255,0.1);padding-top:12px;"><button id="gh-p-clear" style="background:#ff5f56;color:white;border:none;padding:8px;border-radius:8px;cursor:pointer;flex:1;font-size:12px;font-weight:bold;">Clear</button><button id="gh-p-save" style="background:#007fff;color:white;border:none;padding:8px;border-radius:8px;cursor:pointer;flex:1;font-size:12px;font-weight:bold;">Save</button></div>';document.body.appendChild(w);const sig=document.createElement('div');sig.id='gh-paint-sig';sig.innerText='Mark Saad';sig.style='position:fixed;bottom:20px;right:20px;z-index:99999;font-family:"Courier New",Courier,monospace;font-size:16px;font-weight:bold;color:rgba(255,255,255,0.4);text-shadow:1px 1px 2px rgba(0,0,0,0.8);background:rgba(0,0,0,0.3);padding:6px 12px;border-radius:6px;pointer-events:none;letter-spacing:1px;';document.body.appendChild(sig);window.addEventListener('resize',()=>{const temp=ctx.getImageData(0,0,c.width,c.height);c.width=window.innerWidth;c.height=window.innerHeight;ctx.putImageData(temp,0,0);});c.addEventListener('mousedown',(e)=>{d=true;ctx.beginPath();ctx.moveTo(e.clientX,e.clientY);});c.addEventListener('mousemove',(e)=>{if(!d)return;ctx.lineWidth=document.getElementById('gh-p-size').value;ctx.lineCap='round';ctx.lineJoin='round';if(mode==='brush'){ctx.globalCompositeOperation='source-over';ctx.strokeStyle=document.getElementById('gh-p-color').value;}else{ctx.globalCompositeOperation='destination-out';}ctx.lineTo(e.clientX,e.clientY);ctx.stroke();});const stop=()=>{d=false;};c.addEventListener('mouseup',stop);c.addEventListener('mouseleave',stop);const btnB=document.getElementById('gh-p-brush');const btnE=document.getElementById('gh-p-erase');btnB.addEventListener('click',()=>{mode='brush';btnB.style.background='#00ffcc';btnB.style.color='#111';btnE.style.background='rgba(255,255,255,0.1)';btnE.style.color='white';});btnE.addEventListener('click',()=>{mode='erase';btnE.style.background='#00ffcc';btnE.style.color='#111';btnB.style.background='rgba(255,255,255,0.1)';btnB.style.color='white';});document.getElementById('gh-p-clear').addEventListener('click',()=>{ctx.clearRect(0,0,c.width,c.height);});document.getElementById('gh-p-save').addEventListener('click',()=>{const link=document.createElement('a');link.download='my-artwork.png';link.href=c.toDataURL();link.click();});document.getElementById('gh-p-close').addEventListener('click',()=>{w.remove();c.remove();sig.remove();});})();

